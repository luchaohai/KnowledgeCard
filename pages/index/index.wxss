.page {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.loading-state {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-dialog {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #00d4ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.loading-copy {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-title {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.empty-copy {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.stage-menu {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-shell {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-frame {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.gallery-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.menu-arrow-btn:active {
  transform: scale(0.9);
}

.gallery-arrow-icon {
  width: 32rpx;
  height: 32rpx;
}

.menu-inner-frame {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.menu-gallery {
  width: 100%;
}

.gallery-center {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s;
}

.gallery-center:active {
  transform: scale(0.98);
}

.subject-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.subject-title {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.menu-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.menu-mode-actions {
  display: flex;
  gap: 32rpx;
}

.mode-btn {
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  background: rgba(0, 212, 255, 0.2);
  border: 2rpx solid rgba(0, 212, 255, 0.4);
  transition: all 0.3s;
}

.mode-btn:active {
  background: rgba(0, 212, 255, 0.4);
}

.mode-btn-text {
  font-size: 28rpx;
  color: #00d4ff;
  font-weight: 500;
}

.stage-mode {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-shell {
  width: 100%;
  max-width: 600rpx;
}

.difficulty-frame {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.difficulty-options {
  display: flex;
  gap: 40rpx;
}

.difficulty-option-item {
  flex: 1;
}

.difficulty-btn-container {
  position: relative;
  padding: 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s;
}

.difficulty-btn-container.active {
  background: rgba(0, 212, 255, 0.2);
  border-color: rgba(0, 212, 255, 0.5);
}

.difficulty-btn-pixel-layer {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.difficulty-pixel-row {
  display: flex;
  gap: 4rpx;
}

.difficulty-pixel-row-offset {
  margin-left: 8rpx;
}

.difficulty-pixel {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

.difficulty-pixel-strong {
  background: #00d4ff;
  box-shadow: 0 0 12rpx #00d4ff;
}

.difficulty-pixel-mid {
  background: rgba(0, 212, 255, 0.6);
}

.difficulty-pixel-light {
  background: rgba(0, 212, 255, 0.3);
}

.difficulty-btn-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.difficulty-btn-container.active .difficulty-btn-text {
  color: #00d4ff;
}

.stage-challenge-intro {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.challenge-intro-card {
  width: 100%;
  max-width: 560rpx;
  padding: 32rpx;
}

.challenge-intro-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
}

.challenge-intro-visual {
  width: 100%;
  height: 100%;
}

.challenge-intro-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.challenge-intro-title-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.challenge-intro-symbol {
  position: absolute;
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.3);
}

.symbol-1-corner { top: 32rpx; left: 32rpx; }
.symbol-2-corner { top: 32rpx; right: 32rpx; }
.symbol-3-corner { bottom: 32rpx; left: 32rpx; }
.symbol-4-corner { bottom: 32rpx; right: 32rpx; }

.challenge-intro-number {
  position: absolute;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.number-1 { top: 100rpx; left: 50rpx; }
.number-2 { top: 100rpx; right: 50rpx; }
.number-3 { bottom: 100rpx; left: 50rpx; }
.number-4 { bottom: 100rpx; right: 50rpx; }

.challenge-intro-step {
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 212, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-1 { top: 20%; left: 15%; }
.step-2 { top: 20%; right: 15%; }
.step-3 { bottom: 25%; left: 15%; }
.step-4 { bottom: 25%; right: 15%; }

.challenge-intro-step-text {
  font-size: 22rpx;
  color: #00d4ff;
  font-weight: 600;
}

.challenge-intro-prompt-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

.challenge-intro-phone-arrow-text {
  position: absolute;
  font-size: 48rpx;
  color: rgba(0, 212, 255, 0.5);
  bottom: 40rpx;
}

.phone-arrow-left { left: 40rpx; }
.phone-arrow-right { right: 40rpx; }

.stage-result {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.result-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.result-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.result-badge {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(0, 212, 255, 0.2);
}

.result-badge-text {
  font-size: 28rpx;
  color: #00d4ff;
  font-weight: 600;
}

.result-main {
  margin-bottom: 32rpx;
}

.result-score-panel {
  text-align: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.result-score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.result-score-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin: 16rpx 0;
}

.result-score {
  font-size: 72rpx;
  color: #00d4ff;
  font-weight: 700;
}

.result-score-total {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.4);
}

.result-score-caption {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.result-metrics {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-category-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-category-top {
  display: flex;
  justify-content: space-between;
}

.result-category-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.result-category-percent {
  font-size: 24rpx;
  color: #00d4ff;
}

.result-category-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.result-category-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #00d4ff, #00ff88);
}

.result-category-caption {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.result-ai-panel {
  padding: 24rpx;
  background: rgba(138, 43, 226, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(138, 43, 226, 0.2);
  margin-bottom: 24rpx;
}

.result-ai-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-ai-title {
  font-size: 26rpx;
  color: #8a2be2;
  font-weight: 600;
}

.result-ai-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.result-ai-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.result-pagination {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.result-page-dot-slot {
  display: flex;
}

.result-page-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.result-page-dot-active {
  background: #00d4ff;
}

.study-shell {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.study-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 32rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.study-top-grid {
  display: flex;
  gap: 20rpx;
}

.study-main-column {
  flex: 1;
}

.study-text-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.study-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.study-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.study-page-counter {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
}

.study-page-counter-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.study-text-scroll {
  flex: 1;
  max-height: 300rpx;
}

.study-text-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.study-copy {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.study-copy-card-index {
  font-size: 32rpx;
  color: #00d4ff;
  font-weight: 600;
}

.study-side-column {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.study-keyword-bar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.study-keyword-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.study-keyword-chip {
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(138, 43, 226, 0.2);
}

.study-keyword-chip-text {
  display: flex;
}

.study-keyword-chip-value {
  font-size: 20rpx;
  color: #8a2be2;
}

.study-visual-wrap {
  position: relative;
  width: 100%;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.study-visual-image {
  width: 100%;
  height: 100%;
}

.study-visual-loading {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.study-visual-loading-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.study-bottom-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.study-voice-wrap {
  display: flex;
  justify-content: center;
}

.study-voice-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 165, 0, 0.15);
  border: 2rpx solid rgba(255, 165, 0, 0.3);
  transition: all 0.3s;
}

.study-voice-bar:active {
  background: rgba(255, 165, 0, 0.3);
}

.study-voice-icon {
  width: 40rpx;
  height: 40rpx;
}

.study-voice-text {
  font-size: 28rpx;
  color: #ffa500;
  font-weight: 500;
}

.challenge-score-strip {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.challenge-score-strip-voice {
  margin-top: 8rpx;
}

.challenge-score-item {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.challenge-score-fill-window {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.challenge-score-fill-bar {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.3);
}

.challenge-score-outline {
  width: 100%;
  height: 100%;
}

.study-pagination {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.study-page-dot-slot {
  display: flex;
}

.study-page-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.study-page-dot-active {
  background: #00d4ff;
}